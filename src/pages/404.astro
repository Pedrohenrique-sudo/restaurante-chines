---
import Layout from '../layouts/Layout.astro';

---

<Layout title="Página não encontrada | Dragão Dourado">
  
  
  <section class="relative z-10 min-h-screen flex items-center justify-center px-6 text-center">
    <div>
      <span class="text-[15rem] leading-none animate-bounce block">🐉</span>
      <h1 class="text-6xl md:text-8xl font-black text-gradient mb-6">404</h1>
      <p class="text-cream/40 text-xl mb-4 font-serif">O dragão se perdeu...</p>
      <p class="text-cream/20 mb-10">A página que você procura não existe ou foi movida.</p>
      <a href="/restaurante-chines/" class="btn-primary">Voltar ao Início</a>
    </div>
  </section>
</Layout>

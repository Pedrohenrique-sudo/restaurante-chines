---
import Layout from '../layouts/Layout.astro';
import HeroVideo from '../components/ui/HeroVideo.astro';
---

<Layout title="Dragão Dourado | Alta Gastronomia Chinesa" description="O melhor restaurante chinês do Brasil.">
  
  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <HeroVideo />
    
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none z-[5]">
      <span class="text-[35vw] font-serif text-gold/[0.02] leading-none animate-pulse" style="animation-duration: 4s;">龍</span>
    </div>
    
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <p class="text-gold/50 text-xl md:text-2xl mb-6 tracking-[0.3em] uppercase font-serif" style="animation: fadeIn 1s ease-out forwards;">
        金龙餐厅
      </p>
      
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black mb-8 leading-none">
        <span class="block text-cream" style="animation: slideUp 1s ease-out 0.2s forwards; opacity: 0;">DRAGÃO</span>
        <span class="block text-gradient text-[1.3em] mt-4" style="animation: slideUp 1s ease-out 0.4s forwards; opacity: 0;">DOURADO</span>
      </h1>
      
      <p class="text-cream/30 text-lg md:text-xl max-w-xl mx-auto mb-12 font-serif italic" style="animation: fadeIn 1s ease-out 0.6s forwards; opacity: 0;">
        Onde a tradição milenar encontra a sofisticação contemporânea
      </p>
      
      <div class="flex flex-col sm:flex-row gap-5 justify-center" style="animation: fadeIn 1s ease-out 0.8s forwards; opacity: 0;">
        <a href="/restaurante-chines/reservas" class="btn-primary">🏮 Reservar Mesa</a>
        <a href="/restaurante-chines/menu" class="btn-outline">📜 Explorar Menu</a>
      </div>
    </div>

    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 text-gold/20 text-xs tracking-[0.3em] uppercase flex flex-col items-center gap-3">
      <span class="animate-pulse">Scroll</span>
      <svg width="18" height="28" viewBox="0 0 18 28" fill="none" stroke="currentColor" stroke-width="1" class="animate-bounce">
        <rect x="6" y="2" width="6" height="18" rx="3"/>
        <circle cx="9" cy="23" r="2" fill="currentColor" opacity="0.4"/>
      </svg>
    </div>
  </section>

  <!-- AMBIENTE -->
  <section class="relative z-10 py-32 px-6 reveal">
    <div class="max-w-7xl mx-auto">
      <p class="text-gold/50 text-center text-sm tracking-[0.3em] uppercase mb-4">环境</p>
      <h2 class="section-title text-gradient text-center mb-20">O Ambiente</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { img: 'https://images.unsplash.com/photo-1552566626-52f8b828add9?w=600&q=80', title: 'Salão Imperial', desc: 'Lustres de seda e madeira nobre entalhada à mão' },
          { img: 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600&q=80', title: 'Terraço Jardim', desc: 'Bambuzais centenários e lago de carpas ornamentais' },
          { img: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&q=80', title: 'Sala VIP', desc: 'Experiência exclusiva com menu degustação personalizado' },
        ].map(item => (
          <div class="glass-card overflow-hidden group cursor-pointer reveal-card">
            <div class="h-64 overflow-hidden">
              <img src={item.img} alt={item.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 parallax-simple" loading="lazy" />
            </div>
            <div class="p-8">
              <h3 class="text-gold font-serif text-2xl mb-3">{item.title}</h3>
              <p class="text-cream/30 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRATOS DESTAQUE -->
  <section class="relative z-10 py-32 px-6 reveal">
    <div class="max-w-7xl mx-auto">
      <p class="text-gold/50 text-center text-sm tracking-[0.3em] uppercase mb-4">招牌菜</p>
      <h2 class="section-title text-gradient text-center mb-8">Pratos Assinatura</h2>
      <div class="w-24 h-[1px] bg-gradient-to-r from-gold/60 to-transparent mx-auto mb-16 line-draw"></div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { img: 'https://images.unsplash.com/photo-1563245372-f21724e3856d?w=600&q=80', name: 'Pato de Pequim', price: 'R$ 189', desc: 'Assado lentamente com pele crocante e molho hoisin artesanal' },
          { img: 'https://images.unsplash.com/photo-1569058242253-92a9c755a0ec?w=600&q=80', name: 'Dim Sum Premium', price: 'R$ 98', desc: 'Seleção de 12 peças artesanais cozidas no vapor' },
          { img: 'https://images.unsplash.com/photo-1555126634-323283e090fa?w=600&q=80', name: 'Lamen do Chef', price: 'R$ 76', desc: 'Caldo tonkotsu 18h com macarrão artesanal e porco chashu' },
        ].map(prato => (
          <div class="glass-card overflow-hidden group cursor-pointer reveal-card">
            <div class="h-72 overflow-hidden">
              <img src={prato.img} alt={prato.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 parallax-simple" loading="lazy" />
            </div>
            <div class="p-8">
              <div class="flex justify-between items-start mb-3">
                <h3 class="text-gold font-serif text-2xl">{prato.name}</h3>
                <span class="text-gradient text-xl font-bold">{prato.price}</span>
              </div>
              <p class="text-cream/30 text-sm leading-relaxed">{prato.desc}</p>
            </div>
          </div>
        ))}
      </div>
      
      <div class="text-center mt-16 reveal-scale">
        <a href="/restaurante-chines/menu" class="btn-outline">Ver Cardápio Completo</a>
      </div>
    </div>
  </section>

  <!-- CHEF -->
  <section class="relative z-10 py-32 px-6 reveal">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="reveal-left">
        <p class="text-gold/50 text-sm tracking-[0.3em] uppercase mb-4">主厨</p>
        <h2 class="section-title text-gradient mb-10">Chef Antonio Danilo</h2>
        <div class="space-y-6 text-cream/40 text-lg leading-relaxed">
          <p>Descendente de chefs que serviram a <strong class="text-gold">dinastia Qing</strong>, o Chef Antonio Danilo traz segredos culinários de mais de 300 anos.</p>
          <p>Formado no <strong class="text-gold">Le Cordon Bleu Paris</strong> e com passagens por restaurantes 3 estrelas Michelin em Hong Kong.</p>
        </div>
        <a href="/restaurante-chines/sobre" class="btn-outline mt-10 inline-block">Nossa História</a>
      </div>
      <div class="glass-card overflow-hidden reveal-right">
        <img src="https://images.unsplash.com/photo-1577219491135-ce391730fb2c?w=600&q=80" alt="Chef Antonio Danilo" class="w-full h-[500px] object-cover parallax-simple" loading="lazy" />
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

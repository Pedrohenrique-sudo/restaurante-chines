---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reservas | Dragão Dourado" description="Reserve sua mesa no Dragão Dourado. Experiência gastronômica única.">
  
  <section class="relative z-10 pt-40 pb-32 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-20 reveal">
        <p class="text-gold/50 text-sm tracking-[0.3em] uppercase mb-4">预订</p>
        <h1 class="section-title text-gradient mb-8">Reservas</h1>
        <div class="w-24 h-[1px] bg-gradient-to-r from-gold/60 to-transparent mx-auto line-draw"></div>
        <p class="text-cream/30 text-lg mt-8 font-serif italic">Garanta sua experiência no melhor restaurante chinês do Brasil</p>
      </div>
      
      <div class="glass-card p-10 reveal">
        <form class="space-y-6" action="https://formspree.io/f/seu-id" method="POST">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <input type="text" name="nome" placeholder="Nome completo" required 
              class="glass-input w-full px-5 py-4 text-cream placeholder-cream/20 text-sm font-serif" />
            <input type="email" name="email" placeholder="E-mail" required 
              class="glass-input w-full px-5 py-4 text-cream placeholder-cream/20 text-sm font-serif" />
            <input type="tel" name="telefone" placeholder="Telefone" required 
              class="glass-input w-full px-5 py-4 text-cream placeholder-cream/20 text-sm font-serif" />
            <input type="number" name="pessoas" placeholder="Nº de pessoas" min="1" max="20" required 
              class="glass-input w-full px-5 py-4 text-cream placeholder-cream/20 text-sm font-serif" />
            <input type="date" name="data" required 
              class="glass-input w-full px-5 py-4 text-cream text-sm font-serif" />
            <input type="time" name="hora" required 
              class="glass-input w-full px-5 py-4 text-cream text-sm font-serif" />
          </div>
          <textarea name="mensagem" rows="3" placeholder="Ocasião especial? Conte-nos!" 
            class="glass-input w-full p-5 text-cream placeholder-cream/20 text-sm font-serif"></textarea>
          <button type="submit" class="btn-primary w-full text-center text-base">🏮 Confirmar Reserva</button>
          <p class="text-center text-cream/20 text-xs pt-2">
            Ou via WhatsApp: <a href="https://wa.me/5511999999999" class="text-gold/60 hover:text-gold transition-colors">(11) 99999-9999</a>
          </p>
        </form>
      </div>
    </div>
  </section>
</Layout>

---
// Componente de fundo 3D com dragão e partículas
---
<div id="three-container" class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true"></div>

<script>
  import * as THREE from 'three';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const container = document.getElementById('three-container');
    if (!container) throw new Error('Container 3D não encontrado');

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    // Partículas de ouro
    const particlesGeometry = new THREE.BufferGeometry();
    const particlesCount = window.innerWidth < 768 ? 300 : 800;
    const posArray = new Float32Array(particlesCount * 3);
    const colorArray = new Float32Array(particlesCount * 3);

    for (let i = 0; i < particlesCount * 3; i += 3) {
      posArray[i] = (Math.random() - 0.5) * 15;
      posArray[i + 1] = (Math.random() - 0.5) * 15;
      posArray[i + 2] = (Math.random() - 0.5) * 10;

      // Cores: dourado e vermelho
      const colorChoice = Math.random();
      if (colorChoice < 0.7) {
        colorArray[i] = 0.83;
        colorArray[i + 1] = 0.63;
        colorArray[i + 2] = 0.09;
      } else {
        colorArray[i] = 0.77;
        colorArray[i + 1] = 0.12;
        colorArray[i + 2] = 0.23;
      }
    }

    particlesGeometry.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
    particlesGeometry.setAttribute('color', new THREE.BufferAttribute(colorArray, 3));

    const particlesMaterial = new THREE.PointsMaterial({
      size: 0.02,
      vertexColors: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      transparent: true,
      opacity: 0.8,
    });

    const particlesMesh = new THREE.Points(particlesGeometry, particlesMaterial);
    scene.add(particlesMesh);

    // Lanternas flutuantes (esferas maiores)
    const lanternGroup = new THREE.Group();
    const lanternGeometry = new THREE.SphereGeometry(0.15, 16, 16);
    
    for (let i = 0; i < 20; i++) {
      const lanternMaterial = new THREE.MeshBasicMaterial({
        color: Math.random() < 0.5 ? 0xD4A017 : 0xC41E3A,
        transparent: true,
        opacity: 0.6 + Math.random() * 0.4,
      });
      
      const lantern = new THREE.Mesh(lanternGeometry, lanternMaterial);
      lantern.position.set(
        (Math.random() - 0.5) * 12,
        (Math.random() - 0.5) * 10,
        -2 - Math.random() * 5
      );
      lantern.userData = {
        speed: 0.2 + Math.random() * 0.5,
        amplitude: 0.5 + Math.random() * 1.5,
        offset: Math.random() * Math.PI * 2,
      };
      lanternGroup.add(lantern);
    }
    scene.add(lanternGroup);

    camera.position.z = 5;

    // Mouse parallax
    let mouseX = 0;
    let mouseY = 0;
    let targetX = 0;
    let targetY = 0;

    window.addEventListener('mousemove', (event) => {
      targetX = (event.clientX / window.innerWidth - 0.5) * 2;
      targetY = (event.clientY / window.innerHeight - 0.5) * 2;
    });

    // Animação
    const clock = new THREE.Clock();

    function animate() {
      const elapsedTime = clock.getElapsedTime();

      mouseX += (targetX - mouseX) * 0.05;
      mouseY += (targetY - mouseY) * 0.05;

      particlesMesh.rotation.y += 0.0002;
      particlesMesh.rotation.x += 0.0001;
      particlesMesh.position.x = mouseX * 0.5;
      particlesMesh.position.y = -mouseY * 0.5;

      lanternGroup.children.forEach((lantern) => {
        const { speed, amplitude, offset } = lantern.userData;
        lantern.position.y += Math.sin(elapsedTime * speed + offset) * 0.002;
        lantern.position.y = Math.max(-5, Math.min(5, lantern.position.y));
      });

      lanternGroup.position.x = mouseX * 0.3;
      lanternGroup.position.y = -mouseY * 0.3;

      camera.position.x = mouseX * 0.2;
      camera.position.y = -mouseY * 0.2;
      camera.lookAt(scene.position);

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }

    animate();

    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
  }
</script>

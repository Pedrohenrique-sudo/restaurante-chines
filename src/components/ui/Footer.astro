<footer class="relative z-10 border-t border-gold/5 bg-[#0A0A0A]" role="contentinfo">
  <!-- Padrão decorativo topo -->
  <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
  
  <div class="max-w-7xl mx-auto px-6 py-20">
    <!-- Grid Principal -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-16">
      
      <!-- Coluna 1 - Marca -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-4 mb-6">
          <span class="text-5xl">🐉</span>
          <div>
            <h3 class="text-gold font-serif text-2xl tracking-wider leading-none">DRAGÃO</h3>
            <p class="text-gold/60 font-serif text-lg tracking-[0.3em] leading-none mt-1">DOURADO</p>
          </div>
        </div>
        
        <p class="text-cream/30 text-sm leading-relaxed mb-6 max-w-sm">
          Excelência em gastronomia chinesa desde 1985. 
          Unindo tradição milenar e sofisticação contemporânea 
          em cada detalhe da sua experiência.
        </p>
        
        <!-- Selos de qualidade -->
        <div class="flex items-center gap-4 mb-6">
          <div class="glass-card px-4 py-2 text-center">
            <span class="text-gold text-lg">⭐</span>
            <p class="text-cream/30 text-[10px] tracking-wider">MICHELIN</p>
          </div>
          <div class="glass-card px-4 py-2 text-center">
            <span class="text-gold text-lg">🏆</span>
            <p class="text-cream/30 text-[10px] tracking-wider">TRIP ADVISOR</p>
          </div>
          <div class="glass-card px-4 py-2 text-center">
            <span class="text-gold text-lg">👨‍🍳</span>
            <p class="text-cream/30 text-[10px] tracking-wider">CHEF PREMIADO</p>
          </div>
        </div>

        <!-- Redes sociais -->
        <div class="flex items-center gap-3">
          {[
            { icon: '📸', label: 'Instagram', href: '#' },
            { icon: '📘', label: 'Facebook', href: '#' },
            { icon: '🐦', label: 'Twitter', href: '#' },
            { icon: '📹', label: 'YouTube', href: '#' },
          ].map(social => (
            <a href={social.href} aria-label={social.label} 
              class="w-10 h-10 rounded-full glass-card flex items-center justify-center text-lg hover:border-gold/40 hover:scale-110 transition-all duration-300 hover:shadow-[0_0_20px_rgba(212,160,23,0.15)]">
              {social.icon}
            </a>
          ))}
        </div>
      </div>

      <!-- Coluna 2 - Navegação -->
      <div>
        <h4 class="text-gold font-serif text-lg mb-6 tracking-wider">NAVEGAÇÃO</h4>
        <ul class="space-y-3">
          {[
            { label: 'Home', href: '/restaurante-chines/' },
            { label: 'Menu Completo', href: '/restaurante-chines/menu' },
            { label: 'Nossa História', href: '/restaurante-chines/sobre' },
            { label: 'Galeria', href: '/restaurante-chines/galeria' },
            { label: 'Reservas', href: '/restaurante-chines/reservas' },
            { label: 'Contato', href: '/restaurante-chines/contato' },
          ].map(link => (
            <li>
              <a href={link.href} 
                class="text-cream/30 hover:text-gold transition-all duration-300 text-sm flex items-center gap-2 group">
                <span class="w-0 h-[1px] bg-gold group-hover:w-3 transition-all duration-300"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Coluna 3 - Horários -->
      <div>
        <h4 class="text-gold font-serif text-lg mb-6 tracking-wider">HORÁRIOS</h4>
        <ul class="space-y-3 text-cream/30 text-sm">
          <li class="flex justify-between">
            <span>Segunda</span>
            <span class="text-gold/50">Fechado</span>
          </li>
          <li class="flex justify-between">
            <span>Terça - Quinta</span>
            <span>11h - 22h</span>
          </li>
          <li class="flex justify-between">
            <span>Sexta - Sábado</span>
            <span>11h - 23h</span>
          </li>
          <li class="flex justify-between">
            <span>Domingo</span>
            <span>12h - 18h</span>
          </li>
          <li class="flex justify-between">
            <span>Feriados</span>
            <span>12h - 20h</span>
          </li>
        </ul>
      </div>

      <!-- Coluna 4 - Newsletter -->
      <div>
        <h4 class="text-gold font-serif text-lg mb-6 tracking-wider">NEWSLETTER</h4>
        <p class="text-cream/30 text-sm mb-4 leading-relaxed">
          Receba novidades, eventos especiais e ofertas exclusivas.
        </p>
        
        <form class="space-y-3" action="https://formspree.io/f/seu-id" method="POST">
          <div class="relative">
            <input 
              type="email" 
              name="email" 
              placeholder="Seu melhor e-mail" 
              required
              class="w-full bg-transparent border border-gold/10 rounded-xl px-4 py-3 text-cream text-sm placeholder-cream/15 focus:border-gold/40 focus:outline-none focus:shadow-[0_0_20px_rgba(212,160,23,0.1)] transition-all duration-300"
            />
          </div>
          <button type="submit" 
            class="w-full px-6 py-3 bg-red-china/80 hover:bg-red-china text-white rounded-xl text-sm tracking-wider transition-all duration-300 hover:shadow-[0_0_25px_rgba(196,30,58,0.4)] font-serif">
            Inscrever-se
          </button>
        </form>
      </div>
    </div>

    <!-- Linha divisória decorativa -->
    <div class="relative py-8">
      <div class="absolute left-0 right-0 top-1/2 h-[1px] bg-gradient-to-r from-transparent via-gold/10 to-transparent"></div>
      <div class="relative flex justify-center">
        <span class="bg-[#0A0A0A] px-6 text-gold/20 font-chinese text-2xl">福</span>
      </div>
    </div>

    <!-- Barra inferior -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8 border-t border-gold/5">
      <p class="text-cream/15 text-xs tracking-wider">
        © {new Date().getFullYear()} Dragão Dourado Restaurante • 金龙餐厅 • Todos os direitos reservados
      </p>
      
      <div class="flex items-center gap-6 text-cream/15 text-xs tracking-wider">
        <a href="#" class="hover:text-gold/50 transition-colors">Política de Privacidade</a>
        <a href="#" class="hover:text-gold/50 transition-colors">Termos de Uso</a>
        <span>CNPJ: 00.000.000/0001-00</span>
      </div>
    </div>
  </div>

  <!-- Caractere decorativo canto -->
  <div class="absolute bottom-4 right-6 text-[8rem] font-chinese text-gold/[0.015] pointer-events-none select-none leading-none" aria-hidden="true">
    龍
  </div>
</footer>

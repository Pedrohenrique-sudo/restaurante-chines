<script>
  // Sistema de animação de scroll SUAVE e PROFISSIONAL
  function initScrollReveal() {
    const options = {
      threshold: 0.2,
      rootMargin: '0px 0px -40px 0px',
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, options);

    // Observar elementos
    document.querySelectorAll('.reveal, .reveal-card, .reveal-left, .reveal-right, .reveal-scale, .line-draw').forEach(el => {
      observer.observe(el);
    });

    // Parallax suave
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          document.querySelectorAll('.parallax-simple').forEach(img => {
            const rect = img.parentElement.getBoundingClientRect();
            const scrolled = rect.top / window.innerHeight;
            img.style.transform = `translateY(${scrolled * 25}px) scale(1.05)`;
          });
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollReveal);
  } else {
    initScrollReveal();
  }
</script>

<style>
  /* Revelação padrão */
  .reveal {
    opacity: 0;
    transform: translateY(50px);
    transition: opacity 0.9s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  
  /* Cards com stagger */
  .reveal-card {
    opacity: 0;
    transform: translateY(50px) scale(0.96);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  
  .reveal-card.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  
  .reveal-card:nth-child(1) { transition-delay: 0s; }
  .reveal-card:nth-child(2) { transition-delay: 0.12s; }
  .reveal-card:nth-child(3) { transition-delay: 0.24s; }
  .reveal-card:nth-child(4) { transition-delay: 0.36s; }
  .reveal-card:nth-child(5) { transition-delay: 0.48s; }
  .reveal-card:nth-child(6) { transition-delay: 0.6s; }
  
  /* Slide da esquerda */
  .reveal-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 0.9s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  
  .reveal-left.is-visible {
    opacity: 1;
    transform: translateX(0);
  }
  
  /* Slide da direita */
  .reveal-right {
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.9s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  
  .reveal-right.is-visible {
    opacity: 1;
    transform: translateX(0);
  }
  
  /* Escala elástica */
  .reveal-scale {
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.7s cubic-bezier(0.68, -0.3, 0.27, 1.3),
                transform 0.7s cubic-bezier(0.68, -0.3, 0.27, 1.3);
  }
  
  .reveal-scale.is-visible {
    opacity: 1;
    transform: scale(1);
  }
  
  /* Linha que desenha */
  .line-draw {
    transform: scaleX(0);
    transition: transform 1.1s cubic-bezier(0.22, 0.61, 0.36, 1);
    transform-origin: left center;
  }
  
  .line-draw.is-visible {
    transform: scaleX(1);
  }
  
  /* Parallax */
  .parallax-simple {
    transition: transform 0.15s linear;
  }
  
  /* Reduzir movimento */
  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .reveal-card,
    .reveal-left,
    .reveal-right,
    .reveal-scale,
    .line-draw {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

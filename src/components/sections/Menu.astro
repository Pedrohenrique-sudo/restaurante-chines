<section id="menu" class="relative z-10 py-32 px-6 bg-[#0A0A0A]">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20">
      <p class="section-subtitle mb-4">菜单</p>
      <h2 class="section-title text-gradient">Menu Exclusivo</h2>
      <p class="text-cream/40 text-lg mt-4">Pratos selecionados pelo Chef Antonio Danilo</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {[
        { name: 'Pato de Pequim', chinese: '北京烤鸭', price: 'R$ 189', tag: 'Chef\'s Choice', emoji: '🦆', hot: false },
        { name: 'Dim Sum Premium', chinese: '点心拼盘', price: 'R$ 98', tag: 'Popular', emoji: '🥟', hot: false },
        { name: 'Kung Pao Chicken', chinese: '宫保鸡丁', price: 'R$ 86', tag: 'Picante', emoji: '🌶️', hot: true },
        { name: 'Mapo Tofu', chinese: '麻婆豆腐', price: 'R$ 72', tag: 'Tradicional', emoji: '🧧', hot: true },
        { name: 'Salmão Teriyaki', chinese: '照烧三文鱼', price: 'R$ 129', tag: 'Premium', emoji: '🐉', hot: false },
        { name: 'Lamen do Chef', chinese: '主厨拉面', price: 'R$ 76', tag: 'Exclusivo', emoji: '🍜', hot: true },
      ].map(prato => (
        <div class="glass-card p-6 group cursor-pointer">
          <div class="flex items-start justify-between mb-4">
            <span class="text-4xl group-hover:animate-bounce transition-transform">{prato.emoji}</span>
            <span class="text-[10px] bg-red-china/20 text-red-china px-3 py-1 rounded-full font-serif tracking-wider">{prato.tag}</span>
          </div>
          
          <h3 class="text-gold font-serif text-xl mb-1">{prato.name}</h3>
          <p class="text-cream/30 text-sm font-chinese mb-3">{prato.chinese}</p>
          
          <div class="flex items-center gap-2 mb-4">
            {prato.hot && <span class="text-sm">🌶️</span>}
            <div class="h-[1px] flex-1 bg-gradient-to-r from-gold/30 to-transparent"></div>
          </div>
          
          <div class="flex items-center justify-between">
            <span class="text-2xl font-serif text-gradient">{prato.price}</span>
            <span class="text-cream/20 text-xs">por pessoa</span>
          </div>
          
          <!-- Vapor decorativo -->
          <div class="relative mt-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            <div class="absolute left-1/4 w-1 h-3 bg-cream/10 rounded-full animate-steam"></div>
            <div class="absolute left-1/2 w-1 h-3 bg-cream/10 rounded-full animate-steam" style="animation-delay: 0.3s;"></div>
            <div class="absolute left-3/4 w-1 h-3 bg-cream/10 rounded-full animate-steam" style="animation-delay: 0.6s;"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

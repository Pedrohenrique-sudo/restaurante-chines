<section id="reservas" class="relative z-10 py-32 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-20">
      <p class="section-subtitle mb-4">预订</p>
      <h2 class="section-title text-gradient">Reservas</h2>
      <p class="text-cream/40 text-lg mt-4">Garanta sua experiência no Dragão Dourado</p>
    </div>

    <form class="glass-card p-8 md:p-12 space-y-6" action="https://formspree.io/f/seu-id" method="POST">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { name: 'nome', type: 'text', placeholder: 'Nome completo', icon: '👤' },
          { name: 'email', type: 'email', placeholder: 'E-mail', icon: '✉️' },
          { name: 'telefone', type: 'tel', placeholder: 'Telefone', icon: '📞' },
          { name: 'pessoas', type: 'number', placeholder: 'Nº de pessoas', icon: '👥' },
          { name: 'data', type: 'date', placeholder: '', icon: '📅' },
          { name: 'hora', type: 'time', placeholder: '', icon: '🕐' },
        ].map(field => (
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-cream/30 text-sm">{field.icon}</span>
            <input 
              type={field.type} 
              name={field.name} 
              placeholder={field.placeholder}
              required
              class="w-full bg-transparent border border-gold/10 rounded-xl pl-12 pr-4 py-4 text-cream placeholder-cream/20 focus:border-gold/50 focus:outline-none focus:shadow-[0_0_20px_rgba(212,160,23,0.1)] transition-all duration-300 font-serif"
            />
          </div>
        ))}
      </div>
      
      <textarea name="mensagem" rows="3" placeholder="Mensagem ou ocasião especial (opcional)"
        class="w-full bg-transparent border border-gold/10 rounded-xl p-4 text-cream placeholder-cream/20 focus:border-gold/50 focus:outline-none focus:shadow-[0_0_20px_rgba(212,160,23,0.1)] transition-all duration-300 font-serif"></textarea>
      
      <button type="submit" class="btn-primary w-full text-lg animate-pulse-glow">
        🏮 Confirmar Reserva
      </button>
      
      <p class="text-center text-cream/20 text-xs mt-4">
        Ou faça sua reserva via WhatsApp: <a href="https://wa.me/5511999999999" class="text-gold/60 hover:text-gold transition-colors">(11) 99999-9999</a>
      </p>
    </form>
  </div>
</section>
